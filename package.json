  "scripts": {
    "build": "nest build",
    "build:gateway": "nest build api-gateway",
    "build:auth": "nest build auth",
    "build:chat": "nest build chat",
    "build:notification": "nest build notification",
    "build:filesystem": "nest build filesystem",
    "build:ai": "nest build ai",
    "build:all": "nest build api-gateway && nest build auth && nest build chat && nest build notification && nest build filesystem",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" kafka.topic.ts",
    "start": "nest start",
    "start:gateway": "nest start api-gateway",
    "start:auth": "nest start auth",
    "start:chat": "nest start chat",
    "start:notification": "nest start notification",
    "start:filesystem": "nest start filesystem",
    "start:ai": "nest start ai",
    "start:dev": "nest start --watch",
    "dev:gateway": "nest start api-gateway --watch",
    "dev:auth": "nest start auth --watch",
    "dev:chat": "nest start chat --watch",
    "dev:notification": "nest start notification --watch",
    "dev:filesystem": "nest start filesystem --watch",
    "dev:ai": "nest start ai --watch",
    "dev:all": "concurrently \"yarn dev:gateway\" \"yarn dev:auth\" \"yarn dev:chat\" \"yarn dev:notification\" \"yarn dev:filesystem\" \"yarn dev:ai\"",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/app-nest-be/main",
    "prod:gateway": "node dist/apps/api-gateway/main",
    "prod:auth": "node dist/apps/auth/main",
    "prod:chat": "node dist/apps/chat/main",
    "prod:notification": "node dist/apps/notification/main",
    "prod:filesystem": "node dist/apps/filesystem/main",
    "prod:all": "concurrently \"yarn prod:gateway\" \"yarn prod:auth\" \"yarn prod:chat\" \"yarn prod:notification\" \"yarn prod:filesystem\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/app-nest-be/test/jest-e2e.json",
    "kafka:create-topics": "ts-node -r tsconfig-paths/register libs/scripts/create-topics.ts"
  },
