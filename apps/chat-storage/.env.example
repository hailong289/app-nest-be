# ─────────────────────────────────────────────────────────────────────────────
# chat-storage (write-behind storage consumer)
# Consume topic `chat.messageStore` → bulkWrite message rows vào MongoDB.
# KHÔNG cần Redis. Cloud Run cần HTTP health → PORT bắt buộc (mặc định 8080).
# Copy file này → `.env.development` (local) và set GitHub Secrets (Cloud Run).
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# HTTP health server (Cloud Run yêu cầu lắng nghe $PORT; local tuỳ chọn).
PORT=8080

# ── MongoDB (mongoConfig: mongodb://DB_USER:DB_PASSWORD@DB_HOST , db=DB_NAME) ──
DB_CONNECTION=mongodb
DB_HOST=localhost:27017
DB_NAME=appchat
DB_USER=admin
DB_PASSWORD=password123

# ── Kafka ────────────────────────────────────────────────────────────────────
# Ưu tiên KAFKA_BROKERS; nếu trống dùng KAFKA_HOST:KAFKA_PORT.
KAFKA_BROKERS=
KAFKA_HOST=localhost
KAFKA_PORT=9092
KAFKA_CLIENT_ID=chat-storage
# Consumer group của storage (TÁCH biệt group của chat app). Đây là biến chuẩn
# project mà createKafkaMicroserviceFromApplication đọc (kafkaConfig.consumer).
KAFKA_GROUP_ID=chat-storage-group

# SASL (local redpanda PLAINTEXT → để trống/false; prod set theo broker).
KAFKA_SASL=false
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SASL_MECHANISM=scram-sha-256
KAFKA_SSL=false
