{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@app/constants": [
        "libs/constants/src"
      ],
      "@app/constants/*": [
        "libs/constants/src/*"
      ],
      "@app/dto": [
        "libs/dto/src"
      ],
      "@app/dto/*": [
        "libs/dto/src/*"
      ],
      "@app/grpc": [
        "libs/grpc"
      ],
      "@app/grpc/*": [
        "libs/grpc/*"
      ],
      "@app/helpers": [
        "libs/helpers"
      ],
      "@app/helpers/*": [
        "libs/helpers/*"
      ],
      "@app/schemas": [
        "libs/schemas/src"
      ],
      "@app/database": [
        "libs/database/mongodb/src"
      ],
      "@app/sfu": [
        "libs/sfu/src"
      ],
      "@app/sfu/*": [
        "libs/sfu/src/*"
      ],
      "libs/sfu": [
        "libs/sfu/src"
      ],
      "libs/sfu/*": [
        "libs/sfu/src/*"
      ]
    }
  }
}