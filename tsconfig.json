{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "ignoreDeprecations": "5.0",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    // TS6 bật strictPropertyInitialization theo strictNullChecks → 500+ lỗi DTO
    // (thuộc tính không khởi tạo, vốn được class-validator/Nest gán runtime).
    // Tắt tường minh để giữ hành vi như TS5.x (DTO không cần initializer).
    "strictPropertyInitialization": false,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@app/constants": [
        "./libs/constants/src"
      ],
      "@app/constants/*": [
        "./libs/constants/src/*"
      ],
      "@app/dto": [
        "./libs/dto/src"
      ],
      "@app/dto/*": [
        "./libs/dto/src/*"
      ],
      "@app/grpc": [
        "./libs/grpc"
      ],
      "@app/grpc/*": [
        "./libs/grpc/*"
      ],
      "@app/helpers": [
        "./libs/helpers"
      ],
      "@app/helpers/*": [
        "./libs/helpers/*"
      ],
      "@app/schemas": [
        "./libs/schemas/src"
      ],
      "@app/database": [
        "./libs/database/mongodb/src"
      ],
      "@app/sfu": [
        "./libs/sfu/src"
      ],
      "@app/sfu/*": [
        "./libs/sfu/src/*"
      ],
      "libs/sfu": [
        "./libs/sfu/src"
      ],
      "libs/sfu/*": [
        "./libs/sfu/src/*"
      ],
      "libs/types": [
        "./libs/types/src"
      ],
      "libs/types/*": [
        "./libs/types/src/*"
      ],
      "libs/helpers/src": [
        "./libs/helpers/src"
      ],
      "libs/helpers/src/*": [
        "./libs/helpers/src/*"
      ]
    }
  }
}