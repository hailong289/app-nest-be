        "watchAssets": true,
        "assets": ["**/*.env", "**/*.yaml", "**/*.proto"],
        "tsConfigPath": "libs/grpc/tsconfig.lib.json"
      }
    },
    "helpers": {
      "type": "library",
      "root": "libs/helpers",
      "entryFile": "index",
      "sourceRoot": "libs/helpers/src",
      "compilerOptions": {
        "watchAssets": true,
        "assets": ["**/*.env", "**/*.yaml", "**/*.proto"],
        "tsConfigPath": "libs/helpers/tsconfig.lib.json"
